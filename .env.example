VITE_GEMINI_API_KEY=your_key_here
VITE_OPENAI_API_KEY=your_key_here

# Firebase
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Database
DATABASE_URL=your_neon_connection_string_here

# Firebase Admin (for server-side auth verification)
# Set GOOGLE_APPLICATION_CREDENTIALS environment variable to point to your service account key JSON file
# Or use Application Default Credentials (ADC) if running on Google Cloud